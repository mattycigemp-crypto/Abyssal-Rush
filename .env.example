# Vercel KV / Redis Configuration
# Get these from your Vercel project dashboard under Storage > KV
KV_URL="redis://default:token@host:port"
REDIS_URL="redis://default:token@host:port"

# JWT Secret for authentication
# Generate a strong random string for production
JWT_SECRET="your-secret-key-here"

# Vercel OIDC Token (auto-populated by Vercel CLI)
VERCEL_OIDC_TOKEN=""
